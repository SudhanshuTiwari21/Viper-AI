# Copy to .env and fill in your values.
# Viper AI – environment variables

# -----------------------------------------------------------------------------
# Database (PostgreSQL) – used by @repo/database
# -----------------------------------------------------------------------------
# Where: packages/database (getPool, runMigrations)
# Used for: repositories, repository_files, graph_nodes, graph_edges (Repo Scanner + Graph Builder persistence)
DATABASE_URL=

# -----------------------------------------------------------------------------
# Redis – used when orchestrator pushes parse jobs to the queue
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Qdrant – vector DB for code embeddings (Chunk Embedding Generator)
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=viper_code

# -----------------------------------------------------------------------------
# Backend orchestrator (apps/backend)
# -----------------------------------------------------------------------------
# Where: apps/backend/src/server.ts
# Used for: AI pipeline (Intent Agent, Context Builder, Ranking, Chat/Analysis APIs)
PORT=4000
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Web auth + verification email (apps/backend) — see docs/ENV.md
# -----------------------------------------------------------------------------
# JWT for access tokens (≥32 random chars)
# VIPER_JWT_SECRET=
# VIPER_WEB_APP_URL=http://localhost:3000
# VIPER_WEB_APP_ORIGIN=http://localhost:3000
# VIPER_API_PUBLIC_URL=http://localhost:4000
# Google OAuth (optional)
# VIPER_GOOGLE_CLIENT_ID=
# VIPER_GOOGLE_CLIENT_SECRET=
# Titan / GoDaddy SMTP — sends signup verification link from info@viperai.tech by default
# VIPER_SMTP_HOST=smtp.titan.email
# VIPER_SMTP_PORT=465
# VIPER_SMTP_USER=info@viperai.tech
# VIPER_SMTP_PASS=
# VIPER_MAIL_FROM=Viper AI <info@viperai.tech>
# Local dev without SMTP: VIPER_AUTH_LOG_VERIFY_TOKEN=1 or VIPER_AUTH_SKIP_EMAIL_VERIFICATION=1

# -----------------------------------------------------------------------------
# IDE / Viper Desktop (apps/viper-desktop)
# -----------------------------------------------------------------------------
# Where: apps/viper-desktop/ui/services/agent-api.ts (Vite env)
# Used for: Chat and Analysis requests from the IDE to the backend. Must be set at build time for Electron.
# Default: http://localhost:4000
# VITE_AGENT_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# OpenAI – LLM and Embeddings (required for real providers)
# -----------------------------------------------------------------------------
# Intent Reasoner (LLM): packages/agents/intent-agent/modules/intent-reasoner/llm-client.service.ts
# Direct Chat (LLM): apps/backend/src/services/assistant.service.ts (runDirectLLM)
# Codebase Analysis Agent (embeddings only, no LLM): .../openai-embedding.adapter.ts — used when running full analysis (POST /analysis/run).
OPENAI_API_KEY=

# Chat / reasoning model (default gpt-4o-mini). Not used by Analysis Agent.
OPENAI_MODEL=gpt-4o-mini

# Embedding model (default text-embedding-3-small). Used by Analysis Agent for chunk embeddings.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Caching and batching (optional – @repo/shared, intent-agent, backend, codebase-analysis-agent)
# -----------------------------------------------------------------------------
# LLM reasoning cache TTL in seconds (default 3600 = 1 hour)
LLM_CACHE_TTL=3600
# Direct LLM chat cache TTL in seconds (default 900 = 15 minutes)
DIRECT_LLM_CACHE_TTL=900
# Embedding cache TTL in seconds (default 604800 = 7 days)
EMBEDDING_CACHE_TTL=604800
# Max texts per OpenAI embedding request (default 64, max 256)
EMBEDDING_BATCH_SIZE=64

# -----------------------------------------------------------------------------
# Viper Desktop (apps/viper-desktop) — Vite build-time (`VITE_*`)
# -----------------------------------------------------------------------------
# VITE_AGENT_API_URL=http://localhost:4000
# VITE_WEB_APP_URL=http://localhost:3000
