# Copy to .env and fill in your values.
# Viper AI – environment variables

# -----------------------------------------------------------------------------
# Database (PostgreSQL) – used by @repo/database
# -----------------------------------------------------------------------------
# Where: packages/database/src/database.service.ts (getPool)
# Used for: repository metadata, repository_files (Repo Scanner persistence)
DATABASE_URL=postgresql://neondb_owner:npg_IjLHuNhrv59G@ep-spring-moon-ads4so7m-pooler.c-2.us-east-1.aws.neon.tech/neondb

# -----------------------------------------------------------------------------
# Redis – used when orchestrator pushes parse jobs to the queue
# -----------------------------------------------------------------------------
# Not read from env by default; pass options.redisUrl when calling runRepoScanner,
# or set REDIS_URL and use it when creating RedisQueueService in your app.
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Backend orchestrator (apps/backend)
# -----------------------------------------------------------------------------
# Where: apps/backend/src/server.ts
# Used for: AI pipeline (Intent Agent, Context Builder, Ranking, Chat/Analysis APIs)
PORT=4000
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# IDE / Viper Desktop (apps/viper-desktop)
# -----------------------------------------------------------------------------
# Where: apps/viper-desktop/ui/services/agent-api.ts (Vite env)
# Used for: Chat and Analysis requests from the IDE to the backend. Must be set at build time for Electron.
# Default: http://localhost:4000
# VITE_AGENT_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# LLM / Embedding APIs (optional – not read by code yet; for when real providers are wired)
# -----------------------------------------------------------------------------
# Intent Agent reasoning: packages/agents/intent-agent/modules/intent-reasoner/llm-client.service.ts
#   Currently returns mocked JSON. When wired to OpenAI/Anthropic, the client will need an API key.
# Codebase Analysis embeddings: packages/agents/codebase-analysis-agent/modules/chunk-embedding-generator
#   EmbeddingModelService uses a pluggable adapter (OpenAI, Cohere, local); adapters typically need a key.
# Backend direct LLM (apps/backend runDirectLLM): stub today; future Implementation Agent may need a key.
#
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# COHERE_API_KEY=...
