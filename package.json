{
  "name": "ViperAI",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:backend": "npm run build -w @repo/backend",
    "build:desktop": "npm run build -w viper-desktop",
    "build:desktop:vite": "npm run build:vite -w viper-desktop",
    "build:web": "npm run build -w web-app",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "eval": "npm run eval -w @repo/eval-harness",
    "eval:offline": "npm run eval:offline -w @repo/eval-harness",
    "quality-gate": "npm run check-types -w @repo/workspace-tools && npm run check-types -w @repo/backend && npm test -w @repo/workspace-tools && npm test -w @repo/database && npm test -w @repo/backend && npm test -w @repo/eval-harness && npm run eval -w @repo/eval-harness"
  },
  "devDependencies": {
    "enhanced-resolve": "^5.19.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/agents/*"
  ]
}
